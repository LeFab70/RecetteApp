<ContentPage
    x:Class="RecetteApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:RecetteApp.Converters"
    xmlns:vm="clr-namespace:RecetteApp.ViewModels"
    Title="Recettes - Menu"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:StringToImageSourceConverter x:Key="ThumbUrl" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding ChargerDonneesCommand}" Order="Primary" Priority="0" Text="Rafraîchir" />
    </ContentPage.ToolbarItems>

    <Grid Padding="12" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">

        <Border
            Grid.Row="0"
            Padding="10"
            BackgroundColor="#FFF3CD"
            IsVisible="{Binding EstFallback}">
            <Label
                HorizontalOptions="Center"
                Text="📴 Hors ligne — affichage des données locales."
                TextColor="#856404" />
        </Border>

        <SearchBar
            Grid.Row="1"
            Placeholder="Rechercher une recette, catégorie, pays…"
            Text="{Binding TexteRecherche}" />

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label
                FontSize="12"
                Opacity="0.75"
                Text="Filtrer par catégorie" />
            <CollectionView
                HeightRequest="56"
                ItemsSource="{Binding CategoriesFil}"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="8" Orientation="Horizontal" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryChipVm">
                        <Border
                            Padding="14,10"
                            Margin="0,0,0,4"
                            BackgroundColor="{Binding Fond}"
                            Stroke="{Binding CouleurBordure}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="{Binding EpaisseurBordure}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectionnerCategorieCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                Text="{Binding Libelle}"
                                TextColor="{Binding CouleurTexte}"
                                VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Border
            Grid.Row="3"
            Padding="10"
            BackgroundColor="{AppThemeBinding Light=#F8D7DA, Dark=#3A1A1D}"
            IsVisible="{Binding EstErreurVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label
                    Grid.Column="0"
                    Text="{Binding MessageErreur}"
                    TextColor="{AppThemeBinding Light=#721C24, Dark=#FFB3BA}" />
                <Button
                    Grid.Column="1"
                    Text="Réessayer"
                    Command="{Binding ReessayerCommand}" />
            </Grid>
        </Border>

        <RefreshView
            Grid.Row="4"
            IsRefreshing="{Binding EstEnChargement}"
            Command="{Binding ChargerDonneesCommand}">
            <Grid RowDefinitions="Auto,*">
                <ActivityIndicator
                    Grid.Row="0"
                    Margin="0,6"
                    HorizontalOptions="Center"
                    IsRunning="{Binding EstEnChargement}"
                    IsVisible="{Binding EstEnChargement}" />

                <CollectionView Grid.Row="1" ItemsSource="{Binding Meals}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MealListRowVm">
                            <Border
                                Margin="6,4"
                                Padding="12"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="16">
                                    <!-- Colonne gauche : texte + aperçu + Détails | [spacer] | cœur -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="12">
                                        <VerticalStackLayout Spacing="6">
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </VerticalStackLayout.GestureRecognizers>
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="2"
                                                Text="{Binding Recette.StrMeal}" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Label FontSize="12" Text="{Binding Recette.StrCategory}" />
                                                <Label FontSize="12" Text="•" />
                                                <Label FontSize="12" Text="{Binding Recette.StrArea}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Label
                                            FontSize="13"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="3"
                                            Opacity="0.85"
                                            Text="{Binding ApercuDescription}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>

                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <Button
                                                Grid.Column="0"
                                                Padding="14,8"
                                                HorizontalOptions="Start"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="10"
                                                FontSize="14"
                                                IsVisible="{Binding PeutFavoriser}"
                                                Text="Détails" />
                                            <Button
                                                Grid.Column="2"
                                                Padding="10,6"
                                                HorizontalOptions="End"
                                                BackgroundColor="Transparent"
                                                BorderWidth="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BasculerFavoriCommand}"
                                                CommandParameter="{Binding .}"
                                                FontSize="26"
                                                IsVisible="{Binding PeutFavoriser}"
                                                Text="{Binding SymboleCoeur}"
                                                TextColor="{Binding CouleurCoeur}"
                                                VerticalOptions="Center" />
                                        </Grid>
                                    </VerticalStackLayout>

                                    <!-- Avatar circulaire à droite, centré verticalement sur la carte -->
                                    <Border
                                        Grid.Column="1"
                                        WidthRequest="96"
                                        HeightRequest="96"
                                        VerticalOptions="Center"
                                        BackgroundColor="{AppThemeBinding Light=#ECEFF1, Dark=#37474F}"
                                        Stroke="{AppThemeBinding Light=#CFD8DC, Dark=#546E7A}"
                                        StrokeShape="RoundRectangle 48"
                                        StrokeThickness="1">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Image Aspect="AspectFill" Source="{Binding Recette.StrMealThumb, Converter={StaticResource ThumbUrl}}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>

    </Grid>
</ContentPage>
