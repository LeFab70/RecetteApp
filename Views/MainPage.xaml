<ContentPage
    x:Class="RecetteApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RecetteApp.Models"
    Title="Recettes - Menu"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <Grid Padding="12" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">

        <Border
            Grid.Row="0"
            Padding="10"
            BackgroundColor="#FFF3CD"
            IsVisible="{Binding EstFallback}">
            <Label
                HorizontalOptions="Center"
                Text="📴 Hors ligne — affichage des données locales."
                TextColor="#856404" />
        </Border>

        <SearchBar
            Grid.Row="1"
            Placeholder="Rechercher une recette, catégorie, pays…"
            Text="{Binding TexteRecherche}" />

        <Border
            Grid.Row="2"
            Padding="10"
            BackgroundColor="{AppThemeBinding Light=#F8D7DA, Dark=#3A1A1D}"
            IsVisible="{Binding EstErreurVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label
                    Grid.Column="0"
                    Text="{Binding MessageErreur}"
                    TextColor="{AppThemeBinding Light=#721C24, Dark=#FFB3BA}" />
                <Button
                    Grid.Column="1"
                    Text="Réessayer"
                    Command="{Binding ReessayerCommand}" />
            </Grid>
        </Border>

        <RefreshView
            Grid.Row="3"
            IsRefreshing="{Binding EstEnChargement}"
            Command="{Binding ChargerDonneesCommand}">
            <Grid RowDefinitions="Auto,*">
                <ActivityIndicator
                    Grid.Row="0"
                    Margin="0,6"
                    HorizontalOptions="Center"
                    IsRunning="{Binding EstEnChargement}"
                    IsVisible="{Binding EstEnChargement}" />

                <CollectionView Grid.Row="1" ItemsSource="{Binding Meals}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Meal">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem
                                            Text="Favori"
                                            BackgroundColor="#2E7D32"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AjouterAuxFavorisCommand}"
                                            CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Border
                                    Margin="6,4"
                                    Padding="10"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

                                    <Grid ColumnDefinitions="88,*" ColumnSpacing="12">
                                        <Border
                                            WidthRequest="88"
                                            HeightRequest="88"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{AppThemeBinding Light=#F1F3F5, Dark=#2A2A2A}">
                                            <Image
                                                Aspect="AspectFill"
                                                Source="{Binding StrMealThumb}" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding StrMeal}" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Label FontSize="12" Text="{Binding StrCategory}" />
                                                <Label FontSize="12" Text="•" />
                                                <Label FontSize="12" Text="{Binding StrArea}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>

    </Grid>
</ContentPage>