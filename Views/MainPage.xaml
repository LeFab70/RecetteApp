<ContentPage
    x:Class="RecetteApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RecetteApp.Models"
    Title="Recettes - Menu"
    BackgroundColor="Azure">

    <Grid Padding="10" RowDefinitions="Auto,Auto,*">

        <Border
            Grid.Row="0"
            Padding="10"
            BackgroundColor="#FFF3CD"
            IsVisible="{Binding EstFallback}">
            <Label
                HorizontalOptions="Center"
                Text="Mode hors ligne : affichage des données locales."
                TextColor="#856404" />
        </Border>

        <ActivityIndicator
            Grid.Row="1"
            Margin="0,10"
            HorizontalOptions="Center"
            IsRunning="{Binding EstEnChargement}"
            IsVisible="{Binding EstEnChargement}" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Meals}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Meal">
                    <Border
                        Margin="5"
                        Padding="10"
                        StrokeShape="RoundRectangle 10">

                        <HorizontalStackLayout Spacing="10">
                            <Image
                                Aspect="AspectFill"
                                HeightRequest="80"
                                Source="{Binding StrMealThumb}"
                                WidthRequest="80" />

                            <VerticalStackLayout>
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding StrMeal}" />

                                <Label FontSize="12" Text="{Binding StrCategory}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>