<ContentPage
    x:Class="RecetteApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:RecetteApp.Converters"
    xmlns:vm="clr-namespace:RecetteApp.ViewModels"
    Title="Recettes - Menu"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:StringToImageSourceConverter x:Key="ThumbUrl" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding ChargerDonneesCommand}" Order="Primary" Priority="0" Text="Rafraîchir" />
    </ContentPage.ToolbarItems>

    <Grid
        x:Name="RootGrid"
        Padding="12"
        Opacity="0"
        RowDefinitions="Auto,Auto,Auto,Auto,*"
        RowSpacing="10">

        <Border
            Grid.Row="0"
            Padding="10"
            BackgroundColor="#FFF3CD"
            IsVisible="{Binding EstFallback}">
            <Label
                HorizontalOptions="Center"
                Text="📴 Hors ligne — affichage des données locales."
                TextColor="#856404" />
        </Border>

        <SearchBar
            Grid.Row="1"
            Placeholder="Rechercher une recette, catégorie, pays…"
            Text="{Binding TexteRecherche}" />

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label
                FontSize="12"
                Opacity="0.75"
                Text="Filtrer par catégorie" />
            <CollectionView
                HeightRequest="56"
                ItemsSource="{Binding CategoriesFil}"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="8" Orientation="Horizontal" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryChipVm">
                        <Border
                            Padding="14,10"
                            Margin="0,0,0,4"
                            BackgroundColor="{Binding Fond}"
                            Stroke="{Binding CouleurBordure}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="{Binding EpaisseurBordure}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectionnerCategorieCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                Text="{Binding Libelle}"
                                TextColor="{Binding CouleurTexte}"
                                VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Border
            Grid.Row="3"
            Padding="10"
            BackgroundColor="{AppThemeBinding Light=#F8D7DA, Dark=#3A1A1D}"
            IsVisible="{Binding EstErreurVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label
                    Grid.Column="0"
                    Text="{Binding MessageErreur}"
                    TextColor="{AppThemeBinding Light=#721C24, Dark=#FFB3BA}" />
                <Button
                    Grid.Column="1"
                    Text="Réessayer"
                    Command="{Binding ReessayerCommand}" />
            </Grid>
        </Border>

        <RefreshView
            Grid.Row="4"
            IsRefreshing="{Binding EstEnChargement}"
            Command="{Binding ChargerDonneesCommand}">
            <Grid RowDefinitions="Auto,Auto,*">
                <ActivityIndicator
                    Grid.Row="0"
                    Margin="0,6"
                    HorizontalOptions="Center"
                    IsRunning="{Binding EstEnChargement}"
                    IsVisible="{Binding EstEnChargement}" />

                <Border
                    Grid.Row="1"
                    Margin="0,4,0,6"
                    Padding="14,12"
                    BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E33}"
                    IsVisible="{Binding AfficherMessageVideCategorie}"
                    Stroke="{AppThemeBinding Light=#90CAF9, Dark=#5C6BC0}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1">
                    <Label
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"
                        Text="{Binding MessageVideCategorie}"
                        TextColor="{AppThemeBinding Light=#0D47A1, Dark=#90CAF9}" />
                </Border>

                <CollectionView Grid.Row="2" ItemsSource="{Binding Meals}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            Padding="18,22"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="10">
                            <Label FontSize="26" HorizontalOptions="Center" Text="🍽️" />
                            <Label
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                Text="Aucune recette trouvée" />
                            <Label
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                Opacity="0.75"
                                Text="Essaie une autre recherche ou reviens sur « Toutes »." />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MealListRowVm">
                            <Border
                                Margin="6,4"
                                Padding="12"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="{AppThemeBinding Light=#00000022, Dark=#000000AA}"
                                        Opacity="0.22"
                                        Radius="16"
                                        Offset="0,6" />
                                </Border.Shadow>

                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="16">
                                    <!-- Colonne gauche : texte + aperçu + Détails -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="12">
                                        <VerticalStackLayout Spacing="6">
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </VerticalStackLayout.GestureRecognizers>
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="2"
                                                Text="{Binding Recette.StrMeal}" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Label FontSize="12" Text="{Binding Recette.StrCategory}" />
                                                <Label FontSize="12" Text="•" />
                                                <Label FontSize="12" Text="{Binding Recette.StrArea}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Label
                                            FontSize="13"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="3"
                                            Opacity="0.85"
                                            Text="{Binding ApercuDescription}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>

                                        <Button
                                            Padding="14,8"
                                            HorizontalOptions="Start"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="10"
                                            FontSize="14"
                                            IsVisible="{Binding PeutFavoriser}"
                                            Text="Détails" />
                                    </VerticalStackLayout>

                                    <!-- Droite : cœur en haut, avatar circulaire en dessous, bloc centré verticalement -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="8"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center">
                                        <Button
                                            Padding="4"
                                            HorizontalOptions="End"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BasculerFavoriCommand}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnHeartClicked"
                                            FontSize="26"
                                            IsVisible="{Binding PeutFavoriser}"
                                            Text="{Binding SymboleCoeur}"
                                            TextColor="{Binding CouleurCoeur}" />
                                        <Border
                                            WidthRequest="96"
                                            HeightRequest="96"
                                            HorizontalOptions="End"
                                            BackgroundColor="{AppThemeBinding Light=#ECEFF1, Dark=#37474F}"
                                            Stroke="{AppThemeBinding Light=#CFD8DC, Dark=#546E7A}"
                                            StrokeShape="RoundRectangle 48"
                                            StrokeThickness="1">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Image Aspect="AspectFill" Source="{Binding Recette.StrMealThumb, Converter={StaticResource ThumbUrl}}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>

    </Grid>
</ContentPage>
