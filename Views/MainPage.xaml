<ContentPage
    x:Class="RecetteApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RecetteApp.ViewModels"
    Title="Recettes - Menu"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <Grid Padding="12" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">

        <Border
            Grid.Row="0"
            Padding="10"
            BackgroundColor="#FFF3CD"
            IsVisible="{Binding EstFallback}">
            <Label
                HorizontalOptions="Center"
                Text="📴 Hors ligne — affichage des données locales."
                TextColor="#856404" />
        </Border>

        <SearchBar
            Grid.Row="1"
            Placeholder="Rechercher une recette, catégorie, pays…"
            Text="{Binding TexteRecherche}" />

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label
                FontSize="12"
                Opacity="0.75"
                Text="Filtrer par catégorie" />
            <CollectionView
                HeightRequest="56"
                ItemsSource="{Binding CategoriesFil}"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="8" Orientation="Horizontal" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryChipVm">
                        <Border
                            Padding="14,10"
                            Margin="0,0,0,4"
                            BackgroundColor="{Binding Fond}"
                            Stroke="{Binding CouleurBordure}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="{Binding EpaisseurBordure}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectionnerCategorieCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                Text="{Binding Libelle}"
                                TextColor="{Binding CouleurTexte}"
                                VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Border
            Grid.Row="3"
            Padding="10"
            BackgroundColor="{AppThemeBinding Light=#F8D7DA, Dark=#3A1A1D}"
            IsVisible="{Binding EstErreurVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label
                    Grid.Column="0"
                    Text="{Binding MessageErreur}"
                    TextColor="{AppThemeBinding Light=#721C24, Dark=#FFB3BA}" />
                <Button
                    Grid.Column="1"
                    Text="Réessayer"
                    Command="{Binding ReessayerCommand}" />
            </Grid>
        </Border>

        <RefreshView
            Grid.Row="4"
            IsRefreshing="{Binding EstEnChargement}"
            Command="{Binding ChargerDonneesCommand}">
            <Grid RowDefinitions="Auto,*">
                <ActivityIndicator
                    Grid.Row="0"
                    Margin="0,6"
                    HorizontalOptions="Center"
                    IsRunning="{Binding EstEnChargement}"
                    IsVisible="{Binding EstEnChargement}" />

                <CollectionView Grid.Row="1" ItemsSource="{Binding Meals}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MealListRowVm">
                            <Border
                                Margin="6,4"
                                Padding="10"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

                                <VerticalStackLayout Spacing="10">
                                    <!-- Haut : image + titre / métadonnées -->
                                    <Grid ColumnDefinitions="88,*" ColumnSpacing="12">
                                        <Border
                                            Grid.Column="0"
                                            WidthRequest="88"
                                            HeightRequest="88"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{AppThemeBinding Light=#F1F3F5, Dark=#2A2A2A}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Image Aspect="AspectFill" Source="{Binding Recette.StrMealThumb}" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </VerticalStackLayout.GestureRecognizers>
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding Recette.StrMeal}" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Label FontSize="12" Text="{Binding Recette.StrCategory}" />
                                                <Label FontSize="12" Text="•" />
                                                <Label FontSize="12" Text="{Binding Recette.StrArea}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- Bas : aperçu … | cœur -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label
                                            Grid.Column="0"
                                            FontSize="13"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="2"
                                            Opacity="0.85"
                                            Text="{Binding ApercuDescription}"
                                            VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>

                                        <Button
                                            Grid.Column="1"
                                            Padding="8,4"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BasculerFavoriCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="26"
                                            IsVisible="{Binding PeutFavoriser}"
                                            Text="{Binding SymboleCoeur}"
                                            TextColor="{Binding CouleurCoeur}"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>

    </Grid>
</ContentPage>
