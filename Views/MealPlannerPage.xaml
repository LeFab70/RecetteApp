<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="RecetteApp.Views.MealPlannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:RecetteApp.Converters"
    xmlns:vm="clr-namespace:RecetteApp.ViewModels"
    Title="Planificateur"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:StringToImageSourceConverter x:Key="ThumbUrl" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding RafraichirListeRepasCommand}" Order="Primary" Priority="0" Text="Rafraîchir" />
    </ContentPage.ToolbarItems>

    <Grid Padding="12" RowDefinitions="Auto,Auto,2*,3*" RowSpacing="14">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label
                Grid.Column="0"
                FontSize="14"
                LineBreakMode="WordWrap"
                Opacity="0.88"
                Text="Liste déroulante ou carte : sélectionne un jour, puis touche une vignette pour l’assigner."
                VerticalOptions="Center" />
            <ActivityIndicator
                Grid.Column="1"
                VerticalOptions="Center"
                IsRunning="{Binding EstEnChargement}"
                IsVisible="{Binding EstEnChargement}"
                WidthRequest="36" />
        </Grid>

        <!-- Jour actif : liste déroulante bien visible -->
        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Label
                FontAttributes="Bold"
                FontSize="17"
                Text="Jour actif"
                TextColor="{AppThemeBinding Light=#1B5E20, Dark=#A5D6A7}" />
            <Picker
                Title="Choisir le jour"
                FontSize="18"
                ItemDisplayBinding="{Binding Titre}"
                ItemsSource="{Binding Jours}"
                MinimumHeightRequest="52"
                SelectedItem="{Binding JourSelectionne, Mode=TwoWay}" />
        </VerticalStackLayout>

        <!-- Semaine : cartes plus grandes -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Jours}" SelectionMode="None" VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:JourPlanVm">
                    <Border
                        Margin="0,2"
                        Padding="16,14"
                        BackgroundColor="{Binding CouleurFondCarte}"
                        MinimumHeightRequest="118"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0">
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding EstSelectionne}" TargetType="Border" Value="True">
                                <Setter Property="Stroke" Value="{AppThemeBinding Light=#1B5E20, Dark=#81C784}" />
                                <Setter Property="StrokeThickness" Value="4" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EstSelectionne}" TargetType="Border" Value="False">
                                <Setter Property="Stroke" Value="Transparent" />
                                <Setter Property="StrokeThickness" Value="0" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectionnerJourCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="24"
                                LineBreakMode="TailTruncation"
                                Text="{Binding Titre}"
                                TextColor="{Binding CouleurTexteTitre}"
                                VerticalOptions="Center" />

                            <Button
                                Grid.Row="0"
                                Grid.Column="1"
                                Padding="14,8"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EffacerJourCommand}"
                                CommandParameter="{Binding .}"
                                CornerRadius="10"
                                FontSize="13"
                                IsVisible="{Binding AUnRepasPlanifie}"
                                Text="Effacer"
                                VerticalOptions="Center" />

                            <Grid
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="14">
                                <Border
                                    Grid.Column="0"
                                    HeightRequest="72"
                                    IsVisible="{Binding AUnRepasPlanifie}"
                                    Stroke="{AppThemeBinding Light=#00000018, Dark=#FFFFFF22}"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    WidthRequest="72">
                                    <Image Aspect="AspectFill" Source="{Binding RepasChoisi.StrMealThumb, Converter={StaticResource ThumbUrl}}" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        IsVisible="{Binding AUnRepasPlanifie}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2"
                                        Text="{Binding RepasChoisi.StrMeal}"
                                        TextColor="{Binding CouleurTexteTitre}" />
                                    <Label
                                        FontSize="15"
                                        IsVisible="{Binding SansRepasPlanifie}"
                                        LineBreakMode="WordWrap"
                                        Opacity="0.82"
                                        Text="Aucun repas — choisis une vignette dans la liste ci-dessous."
                                        TextColor="{Binding CouleurTexteTitre}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">

            <Label
                Grid.Row="0"
                FontAttributes="Bold"
                FontSize="16"
                Text="Recettes (TheMealDB)"
                TextColor="{AppThemeBinding Light=#1B5E20, Dark=#A5D6A7}" />

            <Label
                Grid.Row="1"
                FontSize="12"
                IsVisible="{Binding AErreurListe}"
                LineBreakMode="WordWrap"
                Text="{Binding ErreurListeRepas}"
                TextColor="{AppThemeBinding Light=#B71C1C, Dark=#FFCDD2}" />

            <Grid Grid.Row="2">
                <CollectionView
                    x:Name="RepasCollection"
                    ItemsSource="{Binding TuilesRepas}"
                    RemainingItemsThreshold="8"
                    RemainingItemsThresholdReached="OnRepasRemainingThreshold"
                    SelectionMode="None"
                    VerticalOptions="Fill">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            HorizontalItemSpacing="10"
                            Orientation="Vertical"
                            Span="2"
                            VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label
                            Margin="0,28"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Opacity="0.65"
                            Text="Les vignettes apparaîtront ici. Tire pour charger plus de repas." />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlannerMealTileVm">
                            <Border
                                Padding="8"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                                Stroke="{AppThemeBinding Light=#00000014, Dark=#FFFFFF18}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AssignerTuileAuJourSelectionneCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6">
                                    <Border HeightRequest="78" StrokeShape="RoundRectangle 10">
                                        <Image Aspect="AspectFill" Source="{Binding StrMealThumb, Converter={StaticResource ThumbUrl}}" />
                                    </Border>
                                    <Label
                                        FontSize="12"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2"
                                        Text="{Binding StrMeal}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <ActivityIndicator
                    Margin="0,0,0,8"
                    HorizontalOptions="Center"
                    IsRunning="{Binding EstChargementListePlus}"
                    IsVisible="{Binding EstChargementListePlus}"
                    VerticalOptions="End" />
            </Grid>

            <Label
                Grid.Row="3"
                FontSize="12"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                IsVisible="{Binding PlusDeRepasDisponibles}"
                Opacity="0.75"
                Text="Tu as parcouru tous les lots disponibles pour cette session." />
        </Grid>
    </Grid>
</ContentPage>
