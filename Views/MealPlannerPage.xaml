<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="RecetteApp.Views.MealPlannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RecetteApp.ViewModels"
    Title="Planificateur"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding RafraichirListeRepasCommand}" Order="Primary" Priority="0" Text="Rafraîchir" />
    </ContentPage.ToolbarItems>

    <!-- CollectionView hors ScrollView : évite hauteur 0 sur Android -->
    <Grid Padding="12" RowDefinitions="Auto,*,Auto" RowSpacing="16">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label
                Grid.Column="0"
                FontSize="14"
                LineBreakMode="WordWrap"
                Opacity="0.88"
                Text="Pour chaque jour, choisis un repas dans la liste déroulante. « Charger plus » ajoute des repas TheMealDB à toutes les listes."
                VerticalOptions="Center" />
            <ActivityIndicator
                Grid.Column="1"
                VerticalOptions="Center"
                IsRunning="{Binding EstEnChargement}"
                IsVisible="{Binding EstEnChargement}"
                WidthRequest="36" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Jours}" SelectionMode="None" VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:JourPlanVm">
                    <Border
                        Padding="16,14"
                        BackgroundColor="{Binding CouleurFondCarte}"
                        Stroke="{AppThemeBinding Light=#00000014, Dark=#FFFFFF18}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1">

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label
                                    Grid.Column="0"
                                    FontAttributes="Bold"
                                    FontSize="22"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding Titre}"
                                    TextColor="{Binding CouleurTexteTitre}"
                                    VerticalOptions="Center" />
                                <Button
                                    Grid.Column="1"
                                    Padding="12,6"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EffacerJourCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="10"
                                    FontSize="13"
                                    IsVisible="{Binding AUnRepasPlanifie}"
                                    Text="Effacer"
                                    VerticalOptions="Center" />
                            </Grid>

                            <Picker
                                Title="Repas pour ce jour"
                                FontSize="16"
                                ItemDisplayBinding="{Binding StrMeal}"
                                ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OptionsRepas}"
                                MinimumHeightRequest="52"
                                SelectedItem="{Binding RepasChoisi, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Label
                FontAttributes="Bold"
                FontSize="15"
                Text="Liste des repas (partagée)"
                TextColor="{AppThemeBinding Light=#1B5E20, Dark=#A5D6A7}" />

            <Label
                FontSize="12"
                IsVisible="{Binding AErreurListe}"
                LineBreakMode="WordWrap"
                Text="{Binding ErreurListeRepas}"
                TextColor="{AppThemeBinding Light=#B71C1C, Dark=#FFCDD2}" />

            <Button Command="{Binding ChargerPlusRepasCommand}" Text="Charger plus de repas dans les listes" />

            <Grid HeightRequest="36">
                <ActivityIndicator
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    IsRunning="{Binding EstChargementListePlus}"
                    IsVisible="{Binding EstChargementListePlus}" />
            </Grid>

            <Label
                FontSize="12"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                IsVisible="{Binding PlusDeRepasDisponibles}"
                Opacity="0.75"
                Text="Plus aucun lot à charger pour cette session." />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
