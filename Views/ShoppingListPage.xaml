<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="RecetteApp.Views.ShoppingListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RecetteApp.ViewModels"
    Title="Liste de courses"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <Grid Padding="12" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <Label
            Grid.Row="0"
            FontSize="13"
            Opacity="0.8"
            Text="Coche les articles obtenus — les choix sont enregistrés automatiquement (Preferences)." />

        <HorizontalStackLayout Grid.Row="1" Spacing="10">
            <Button Command="{Binding EffacerCochesCommand}" Text="Retirer les cochés" />
            <Button Command="{Binding ToutEffacerCommand}" Text="Tout effacer" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Articles}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label FontSize="22" HorizontalOptions="Center" Text="🛒" />
                    <Label FontAttributes="Bold" HorizontalOptions="Center" Text="Liste vide" />
                    <Label HorizontalOptions="Center" Opacity="0.75" Text="Ajoute des ingrédients depuis une recette." />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ShoppingItemRow">
                    <Border
                        Margin="4,2"
                        Padding="10"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="Auto,*">
                            <CheckBox Grid.Column="0" VerticalOptions="Center" IsChecked="{Binding IsChecked}" />
                            <Label Grid.Column="1" LineBreakMode="WordWrap" Text="{Binding Text}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
