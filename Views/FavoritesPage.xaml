<ContentPage
    x:Class="RecetteApp.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:RecetteApp.Converters"
    xmlns:models="clr-namespace:RecetteApp.Models"
    Title="Mes Favoris"
    BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:StringToImageSourceConverter x:Key="ThumbUrl" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid
        x:Name="RootGrid"
        Padding="12"
        Opacity="0"
        RowDefinitions="Auto,*"
        RowSpacing="10">
        <ActivityIndicator
            Grid.Row="0"
            HorizontalOptions="Center"
            IsRunning="{Binding EstEnChargement}"
            IsVisible="{Binding EstEnChargement}" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Favoris}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label FontSize="22" Text="⭐" HorizontalOptions="Center" />
                    <Label FontAttributes="Bold" Text="Aucun favori pour l’instant" HorizontalOptions="Center" />
                    <Label Opacity="0.7" Text="Ajoute une recette depuis Recettes ou Détail." HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FavoriteMeal">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem
                                    Text="Supprimer"
                                    BackgroundColor="#D9534F"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SupprimerCommand}"
                                    CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border
                            Margin="6,4"
                            Padding="12"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                            <Border.Shadow>
                                <Shadow
                                    Brush="{AppThemeBinding Light=#00000022, Dark=#000000AA}"
                                    Opacity="0.22"
                                    Radius="16"
                                    Offset="0,6" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="16">
                                <VerticalStackLayout Grid.Column="0" Spacing="12">
                                    <VerticalStackLayout Spacing="6">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                CommandParameter="{Binding .}" />
                                        </VerticalStackLayout.GestureRecognizers>
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="2"
                                            Text="{Binding StrMeal}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label FontSize="12" Text="{Binding StrCategory}" />
                                            <Label FontSize="12" Text="•" />
                                            <Label FontSize="12" Text="{Binding StrArea}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Label
                                        FontSize="13"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="3"
                                        Opacity="0.85"
                                        Text="{Binding TexteApercuAffiche}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <Button
                                        Padding="14,8"
                                        HorizontalOptions="Start"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="10"
                                        FontSize="14"
                                        Text="Détails" />
                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="8"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center">
                                    <Button
                                        Padding="4"
                                        HorizontalOptions="End"
                                        BackgroundColor="Transparent"
                                        BorderWidth="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RetirerFavoriCoeurCommand}"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnHeartClicked"
                                        FontSize="26"
                                        Text="♥"
                                        TextColor="#C62828" />
                                    <Border
                                        WidthRequest="96"
                                        HeightRequest="96"
                                        HorizontalOptions="End"
                                        BackgroundColor="{AppThemeBinding Light=#ECEFF1, Dark=#37474F}"
                                        Stroke="{AppThemeBinding Light=#CFD8DC, Dark=#546E7A}"
                                        StrokeShape="RoundRectangle 48"
                                        StrokeThickness="1">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OuvrirDetailCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Image Aspect="AspectFill" Source="{Binding StrMealThumb, Converter={StaticResource ThumbUrl}}" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
